{
  "name": "ai-automation-e2e",
  "version": "1.0.0",
  "description": "AI Automation End-to-End Testing",
  "main": "dist/index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:nopcommerce": "playwright test tests/nopcommerce*.spec.ts",
    "test:metrics": "bash .github/scripts/orchestrate-tests.sh metrics",
    "test:parallel": "bash .github/scripts/orchestrate-tests.sh parallel",
    "test:flaky": "bash .github/scripts/orchestrate-tests.sh flakiness",
    "build": "tsc",
    "dev": "ts-node",
    "mcp-server": "tsx src/mcp-server.ts",
    "codegen": "playwright codegen",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts' '.github/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts' '.github/**/*.ts'",
    "analyze": "bash .github/scripts/analyze-results.sh analyze",
    "analyze:compare": "bash .github/scripts/analyze-results.sh compare",
    "analyze:trend": "bash .github/scripts/analyze-results.sh trend",
    "quality:check": "npm run lint && npm run format:check && npm run build",
    "quality:fix": "npm run lint:fix && npm run format && npm run build"
  },
  "keywords": [
    "automation",
    "e2e",
    "playwright",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.1",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "@types/nodemailer": "^7.0.11",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.3.1",
    "nodemailer": "^6.9.7",
    "playwright": "^1.40.0"
  }
}
